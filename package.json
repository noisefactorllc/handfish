{
  "name": "@noisedeck/handfish",
  "version": "0.9.0",
  "description": "Handfish Design System - UI components and styles for Noisemaker-based applications",
  "type": "module",
  "main": "src/index.js",
  "exports": {
    ".": "./src/index.js",
    "./styles": "./src/styles/index.css",
    "./styles/*": "./src/styles/*",
    "./components/*": "./src/components/*"
  },
  "files": [
    "src/",
    "dist/"
  ],
  "scripts": {
    "dev": "npx serve . -p 3000",
    "build": "node scripts/bundle.js",
    "test": "npx playwright test",
    "test:update": "npx playwright test --update-snapshots"
  },
  "keywords": [
    "design-system",
    "web-components",
    "ui-components",
    "noisemaker",
    "noisedeck"
  ],
  "author": "Noisedeck",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/noisefactorllc/handfish.git"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "esbuild": "^0.27.3",
    "serve": "^14.0.0"
  }
}
